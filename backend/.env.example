# 数据库配置
DATABASE_URL="mysql://user:password@localhost:3306/medcase_ai?schema=public"

# 服务器配置
PORT=3000
NODE_ENV=development

# JWT配置
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# 星火大模型API配置
XINGHUO_API_URL=https://api.xinghuo.xfyun.cn/v1/chat/completions
XINGHUO_API_KEY=your-api-key-here
XINGHUO_APP_ID=your-app-id
XINGHUO_API_SECRET=your-api-secret

# AI服务配置
AI_TIMEOUT_CASE_GENERATE=30000
AI_TIMEOUT_CHAT_FIRST_CHAR=2000
AI_MAX_RETRIES=1

# 日志级别
LOG_LEVEL=info

# CORS配置
CORS_ORIGIN=http://localhost:5173

# 速率限制
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100